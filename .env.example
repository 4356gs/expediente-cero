EXPEDIENTE_CERO_ENVIRONMENT=development
EXPEDIENTE_CERO_LOG_LEVEL=INFO
EXPEDIENTE_CERO_API_DOCS_ENABLED=true
EXPEDIENTE_CERO_DATABASE_URL=sqlite:///./data/expediente-cero.db
EXPEDIENTE_CERO_OPENAI_MODEL=gpt-5.6
EXPEDIENTE_CERO_OPENAI_TIMEOUT_SECONDS=30
EXPEDIENTE_CERO_FOLLOW_UP_ATTEMPT_LEASE_SECONDS=300
# Tests and normal CI do not require an API key.
# OPENAI_API_KEY=

# Demo lifecycle commands require this explicit boundary. Never use demo reset
# against a database that should be retained.
# EXPEDIENTE_CERO_ENVIRONMENT=demo
